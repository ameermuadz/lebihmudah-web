generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Property {
  id               String            @id
  title            String
  location         String
  price            Int
  rooms            Int
  petsAllowed      Boolean
  ownerId          String
  description      String
  availabilityDate String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  images           PropertyImage[]
  amenities        PropertyAmenity[]
  rules            PropertyRule[]
  ownerMessages    OwnerMessage[]
  bookings         Booking[]
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  bookings     Booking[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PropertyImage {
  id         Int      @id @default(autoincrement())
  propertyId String
  url        String
  sortOrder  Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyAmenity {
  id         Int      @id @default(autoincrement())
  propertyId String
  value      String
  sortOrder  Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyRule {
  id         Int      @id @default(autoincrement())
  propertyId String
  value      String
  sortOrder  Int      @default(0)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model OwnerMessage {
  id         String    @id @default(cuid())
  ownerId    String
  propertyId String
  question   String
  sessionId  String
  status     String    @default("PENDING")
  ownerReply String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([status])
}

model Booking {
  id          String   @id @default(cuid())
  propertyId  String
  userId      String?
  userContact String
  moveInDate  String
  status      String   @default("CONFIRMED")
  createdAt   DateTime @default(now())
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([userId])
}
